# Copy to .env and adjust. All Cavi ERP services read these (prefix: CAVI_).

# PostgreSQL — system of record + schema registry
CAVI_POSTGRES_HOST=localhost
CAVI_POSTGRES_PORT=5432
CAVI_POSTGRES_DB=cavi_erp
CAVI_POSTGRES_USER=cavi
CAVI_POSTGRES_PASSWORD=change-me

# Redis — cache + event bus
CAVI_REDIS_HOST=localhost
CAVI_REDIS_PORT=6379
CAVI_REDIS_DB=0

# n8n middleware
CAVI_N8N_BASE_URL=http://localhost:5678

# Schema registry (directory of versioned JSON Schemas)
CAVI_SCHEMA_REGISTRY_DIR=schema_registry/schemas

# Security
# Shared secret gating the Vault HTTP service (/vend, /sign). REQUIRED in
# production — an empty value makes Vault refuse to sign (fail closed). n8n must
# be given the same value so netsuite-sync can call /sign.
CAVI_VAULT_API_SECRET=
# Optional default-deny tenant allowlist for the Vault service (comma-separated).
# Empty = any tenant with stored credentials.
CAVI_VAULT_TENANT_ALLOWLIST=
# HMAC secret shared with n8n to verify inbound webhook signatures.
CAVI_WEBHOOK_SIGNING_SECRET=
