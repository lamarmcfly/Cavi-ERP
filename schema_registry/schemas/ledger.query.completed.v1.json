{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cavi:ledger.query.completed.v1",
  "title": "Ledger Query Completed",
  "description": "Emitted by Ledger when a read against an ERP resolves successfully. Carries the normalized result set.",
  "type": "object",
  "required": ["tenant_id", "erp_platform", "subject", "filters", "result_count", "payload", "schema_version", "queried_at"],
  "additionalProperties": false,
  "properties": {
    "tenant_id": { "type": "string", "minLength": 1, "description": "Owning tenant. Never empty." },
    "erp_platform": { "type": "string", "minLength": 1, "description": "ERP that served the read." },
    "subject": { "type": "string", "minLength": 1, "description": "Entity queried (e.g. invoices, purchase_orders)." },
    "filters": { "type": "object", "additionalProperties": true, "description": "Free-form filter map applied to the query." },
    "result_count": { "type": "integer", "minimum": 0, "description": "Number of rows returned." },
    "payload": { "type": "array", "items": { "type": "object", "additionalProperties": true }, "description": "Normalized result rows." },
    "schema_version": { "type": "string", "minLength": 1, "description": "Version of the normalized row shape carried in payload." },
    "queried_at": { "type": "string", "format": "date-time", "description": "ISO 8601 completion timestamp." }
  }
}
