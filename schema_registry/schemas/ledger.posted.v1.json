{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cavi:ledger.posted.v1",
  "title": "Ledger Posted",
  "description": "Emitted by Ledger after a balanced journal entry is persisted.",
  "type": "object",
  "required": ["entry_id", "currency", "total_minor", "line_count"],
  "additionalProperties": false,
  "properties": {
    "entry_id": { "type": "string", "format": "uuid" },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "total_minor": { "type": "integer", "minimum": 1, "description": "Total debits (== total credits) in minor units." },
    "line_count": { "type": "integer", "minimum": 2 }
  }
}
