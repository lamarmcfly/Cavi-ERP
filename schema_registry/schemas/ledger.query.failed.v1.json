{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cavi:ledger.query.failed.v1",
  "title": "Ledger Query Failed",
  "description": "Emitted by Ledger when a read against an ERP fails (auth, timeout, unknown subject, upstream error).",
  "type": "object",
  "required": ["tenant_id", "erp_platform", "subject", "filters", "reason", "failed_at"],
  "additionalProperties": false,
  "properties": {
    "tenant_id": { "type": "string", "minLength": 1, "description": "Owning tenant. Never empty." },
    "erp_platform": { "type": "string", "minLength": 1, "description": "ERP that failed to serve the read." },
    "subject": { "type": "string", "minLength": 1, "description": "Entity queried." },
    "filters": { "type": "object", "additionalProperties": true, "description": "Free-form filter map applied to the query." },
    "reason": { "type": "string", "minLength": 1, "description": "Human-readable failure cause." },
    "failed_at": { "type": "string", "format": "date-time", "description": "ISO 8601 failure timestamp." }
  }
}
