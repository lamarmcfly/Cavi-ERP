{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cavi:ledger.rejected.v1",
  "title": "Ledger Rejected",
  "description": "Emitted when a well-formed entry fails a business rule (e.g. debits != credits). Distinct from a schema failure, which is dead-lettered.",
  "type": "object",
  "required": ["entry_id", "currency", "reason", "total_debits", "total_credits"],
  "additionalProperties": false,
  "properties": {
    "entry_id": { "type": "string", "format": "uuid" },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "reason": { "type": "string", "minLength": 1 },
    "total_debits": { "type": "integer", "minimum": 0 },
    "total_credits": { "type": "integer", "minimum": 0 }
  }
}
