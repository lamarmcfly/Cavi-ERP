{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cavi:ledger.entry.v1",
  "title": "Ledger Entry",
  "description": "A balanced double-entry journal posting.",
  "type": "object",
  "required": ["entry_id", "currency", "lines"],
  "additionalProperties": false,
  "properties": {
    "entry_id": { "type": "string", "format": "uuid" },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "memo": { "type": "string", "maxLength": 280 },
    "lines": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["account", "direction", "amount_minor"],
        "additionalProperties": false,
        "properties": {
          "account": { "type": "string" },
          "direction": { "enum": ["debit", "credit"] },
          "amount_minor": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
