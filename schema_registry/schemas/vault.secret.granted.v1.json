{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cavi:vault.secret.granted.v1",
  "title": "Vault Secret Granted",
  "description": "Emitted by Vault when an ERP secret/token is brokered to a caller. Carries the token reference, its scopes, and lifetime — never the key material itself.",
  "type": "object",
  "required": ["tenant_id", "erp_platform", "token_id", "scopes", "expires_at", "issued_at"],
  "additionalProperties": false,
  "properties": {
    "tenant_id": { "type": "string", "minLength": 1, "description": "Owning tenant. Never empty." },
    "erp_platform": { "type": "string", "minLength": 1, "description": "ERP the secret unlocks (e.g. netsuite, sap)." },
    "token_id": { "type": "string", "minLength": 1, "description": "Opaque handle for the brokered token." },
    "scopes": { "type": "array", "items": { "type": "string", "minLength": 1 }, "description": "Capabilities the token authorizes." },
    "expires_at": { "type": "string", "format": "date-time", "description": "ISO 8601 token expiry." },
    "issued_at": { "type": "string", "format": "date-time", "description": "ISO 8601 grant timestamp." }
  }
}
